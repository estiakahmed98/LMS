# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pstc_lms?schema=public"

# AES-256-GCM key for field-level encryption (phone, NID number).
# MUST be exactly 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Secret for signing sessions / JWTs (min 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=""

# Default password assigned to seeded mock users (change after first login)
SEED_DEFAULT_PASSWORD="ChangeMe123!"
