# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pstc_lms?schema=public"

# AES-256-GCM key for field-level encryption (phone, NID number).
# MUST be exactly 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Secret for signing sessions / JWTs (min 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=""

# NextAuth (Auth.js v5) JWT signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Default password assigned to seeded mock users (change after first login)
SEED_DEFAULT_PASSWORD="ChangeMe123!"

# LiveKit (real A/V for /live/[sessionId])
# Create a project at https://cloud.livekit.io → Settings → Keys
# LIVEKIT_URL example: wss://your-project.livekit.cloud
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# Optional — required for durable LiveKit egress recordings (Room Composite → S3/R2).
# In LiveKit Cloud you can also configure storage in the project dashboard.
# LIVEKIT_S3_ACCESS_KEY=""
# LIVEKIT_S3_SECRET=""
# LIVEKIT_S3_BUCKET=""
# LIVEKIT_S3_REGION="auto"
# LIVEKIT_S3_ENDPOINT=""   # e.g. https://<account>.r2.cloudflarestorage.com
